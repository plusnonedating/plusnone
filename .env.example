# =============================================================================
# Plus None environment variables
# =============================================================================
# Copy this file to .env.local for local dev.
# In production these live in Vercel → Project → Settings → Environment Variables.
# See DEPLOYMENT.md for a full walkthrough.
# =============================================================================

# ---------------------------------------------------------------------------
# Submissions base — user submissions from WPForms land here
# ---------------------------------------------------------------------------
# Airtable PAT scoped to the SUBMISSIONS base only.
# Scopes needed: data.records:read, data.records:write
# Generate at: https://airtable.com/create/tokens
AIRTABLE_API_KEY=

# Base ID for the Submissions Airtable base. Hardcoded default.
AIRTABLE_BASE_ID=app1bnUYIncirnxRn

# ---------------------------------------------------------------------------
# Partners base — venue configs powering /scan + geo-gating
# ---------------------------------------------------------------------------
# Airtable PAT scoped to the PARTNERS base only.
# PATs are scoped per-base — this MUST be different from AIRTABLE_API_KEY
# unless you generate one token with both bases included.
# Scopes needed: data.records:read
# Generate at: https://airtable.com/create/tokens
AIRTABLE_BUSINESS_API_KEY=

# Base ID for the Plus None Partners Airtable base.
# Defaults to "appNewsi5A4VKSs4g" in code if unset.
AIRTABLE_BUSINESS_BASE_ID=appNewsi5A4VKSs4g
